<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1E1E1E"
    android:gravity="center"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⚡ مساعد جيني الذكي"
        android:textColor="#03DAC6"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"
        android:gravity="center" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="قبول تلقائي ذكي لطلبات جيني"
        android:textColor="#AAAAAA"
        android:textSize="14sp"
        android:layout_marginBottom="40dp"
        android:gravity="center" />

    <!-- تعليمات الإعداد -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#2D2D2D"
        android:padding="16dp"
        android:layout_marginBottom="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="خطوات الإعداد:"
            android:textColor="#BB86FC"
            android:textStyle="bold"
            android:textSize="14sp"
            android:gravity="end"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="١. اضغط 'تشغيل اللوحة العائمة' ومنح الصلاحية\n٢. اضغط 'خدمة الوصول' وفعّل التطبيق\n٣. افتح جيني وستظهر اللوحة تلقائياً"
            android:textColor="#CCCCCC"
            android:textSize="13sp"
            android:gravity="end"
            android:lineSpacingExtra="4dp" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_start_floating"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="🚀 تشغيل اللوحة العائمة"
        android:backgroundTint="#BB86FC"
        android:textColor="#000000"
        android:textStyle="bold"
        android:textSize="15sp"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btn_open_accessibility"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="⚙️ تفعيل خدمة الوصول (مطلوب)"
        android:backgroundTint="#03DAC6"
        android:textColor="#000000"
        android:textStyle="bold"
        android:textSize="14sp" />

</LinearLayout>
