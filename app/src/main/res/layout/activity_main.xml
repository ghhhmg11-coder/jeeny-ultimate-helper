<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent" android:padding="16dp" android:background="#F5F5F5">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="لوحة تحكم جيني المساعد الذكي" android:textSize="20sp" android:textStyle="bold" android:textColor="#6200EE" android:layout_gravity="center" android:layout_marginBottom="20dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="إعدادات قبول الطلبات:" android:textStyle="bold" android:layout_marginBottom="5dp"/>
        <EditText android:id="@+id/et_min_price" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="الحد الأدنى للسعر (مثال: 15 ريال)" android:inputType="number" android:layout_marginBottom="10dp"/>
        <EditText android:id="@+id/et_max_dist" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="الحد الأقصى للمسافة (مثال: 5 كم)" android:inputType="number" android:layout_marginBottom="15dp"/>

        <Button android:id="@+id/btn_accessibility" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="تفعيل إذن قراءة الشاشة (مهم)" android:backgroundTint="#FF9800" android:layout_marginBottom="10dp"/>
        <Button android:id="@+id/btn_start_floating" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="تشغيل الزر العائم" android:backgroundTint="#6200EE" android:layout_marginBottom="20dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="#FFFFFF" android:padding="15dp" android:elevation="2dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="إحصائيات اليوم" android:textStyle="bold" android:textColor="#000000" android:layout_marginBottom="10dp"/>
            <TextView android:id="@+id/tv_accepted_count" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="إجمالي الرحلات المقبولة تلقائياً: 0" android:textSize="14sp" android:textColor="#4CAF50"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
