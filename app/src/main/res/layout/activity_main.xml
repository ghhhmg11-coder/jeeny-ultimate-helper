<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Jeeny Ultimate Helper" android:textSize="22sp" android:textStyle="bold"
            android:textColor="#6200EE" android:gravity="center" android:layout_marginBottom="4dp"/>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="مساعد جيني الذكي" android:textSize="15sp" android:textColor="#555555"
            android:gravity="center" android:layout_marginBottom="20dp"/>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="الخطوة الأولى: تفعيل خدمة إمكانية الوصول"
            android:textSize="13sp" android:textStyle="bold" android:textColor="#333333"
            android:layout_marginBottom="6dp"/>
        <Button android:id="@+id/btn_open_accessibility"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:text="تفعيل الخدمة في الإعدادات"
            android:textSize="15sp" android:textColor="#FFFFFF"
            android:backgroundTint="#6200EE" android:layout_marginBottom="6dp"/>
        <TextView android:id="@+id/tv_accessibility_status"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="الخدمة غير مفعّلة" android:textSize="13sp"
            android:textColor="#D32F2F" android:gravity="center" android:layout_marginBottom="20dp"/>
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#DDDDDD" android:layout_marginBottom="20dp"/>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="الحد الأدنى للأرباح (ريال)"
            android:textSize="13sp" android:textStyle="bold" android:textColor="#333333"
            android:layout_marginBottom="6dp"/>
        <EditText android:id="@+id/et_min_profit"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:hint="مثال: 10" android:inputType="numberDecimal"
            android:padding="12dp" android:textSize="15sp" android:layout_marginBottom="16dp"/>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="الحد الأقصى لمسافة العميل (كم)"
            android:textSize="13sp" android:textStyle="bold" android:textColor="#333333"
            android:layout_marginBottom="6dp"/>
        <EditText android:id="@+id/et_max_distance"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:hint="مثال: 5" android:inputType="numberDecimal"
            android:padding="12dp" android:textSize="15sp" android:layout_marginBottom="20dp"/>
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#DDDDDD" android:layout_marginBottom="20dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="20dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="تشغيل القبول التلقائي"
                android:textSize="15sp" android:textStyle="bold" android:textColor="#333333"/>
            <Switch android:id="@+id/switch_auto_accept"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>
        <Button android:id="@+id/btn_save"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:text="حفظ الإعدادات" android:textSize="15sp"
            android:textColor="#FFFFFF" android:backgroundTint="#03DAC5"
            android:layout_marginBottom="8dp"/>
        <TextView android:id="@+id/tv_save_status"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="" android:textSize="13sp"
            android:textColor="#388E3C" android:gravity="center"/>
    </LinearLayout>
</ScrollView>
